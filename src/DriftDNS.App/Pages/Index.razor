@page "/"
@using DriftDNS.Core.Interfaces
@using DriftDNS.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject IPublicIpResolver IpResolver
@inject DriftDnsDbContext Db
@inject IDnsSyncService SyncService
@inject IUpdateChecker UpdateChecker

<PageTitle>Overview – DriftDNS</PageTitle>

<h1>Overview</h1>

@if (_updateVersion is not null && !_updateDismissed)
{
    <div class="alert alert-info alert-dismissible d-flex align-items-center gap-2 mt-2" role="alert">
        <span>&#11014; A new version is available: <strong>v@_updateVersion</strong></span>
        <a href="https://github.com/emanueledeamicis/DriftDNS/releases/latest" target="_blank" class="btn btn-sm btn-outline-primary ms-2"><i class="bi bi-box-arrow-up-right me-1"></i>View release</a>
        <button type="button" class="btn-close ms-auto" @onclick="() => _updateDismissed = true"></button>
    </div>
}

<div class="row mt-3">
    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Public IP</h5>
                <p class="card-text fs-4">@(_publicIp ?? "Resolving...")</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Endpoints</h5>
                <p class="card-text fs-4">@_endpointCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Providers</h5>
                <p class="card-text fs-4">@_providerCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Last Sync</h5>
                <p class="card-text">@(_lastSync?.ToString("g") ?? "Never")</p>
            </div>
        </div>
    </div>
</div>

<div class="mt-4">
    <button class="btn btn-primary" @onclick="TriggerSync" disabled="@_syncing">
        @if (_syncing) {
            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
        } else {
            <i class="bi bi-arrow-repeat me-1"></i>
        }
        @(_syncing ? "Syncing..." : "Sync Now")
    </button>
    @if (_syncMessage is not null)
    {
        <span class="ms-3 text-success">@_syncMessage</span>
    }
</div>

@code {
    private string? _publicIp;
    private int _endpointCount;
    private int _providerCount;
    private DateTime? _lastSync;
    private bool _syncing;
    private string? _syncMessage;
    private string? _updateVersion;
    private bool _updateDismissed;

    private static readonly Version _currentVersion =
        typeof(Index).Assembly.GetName().Version ?? new Version(0, 0, 0);

    protected override async Task OnInitializedAsync()
    {
        _publicIp = await IpResolver.ResolveAsync();
        _endpointCount = await Db.DnsEndpoints.CountAsync();
        _providerCount = await Db.ProviderAccounts.CountAsync();
        _lastSync = await Db.SyncLogs
            .OrderByDescending(l => l.Timestamp)
            .Select(l => (DateTime?)l.Timestamp)
            .FirstOrDefaultAsync();

        var latest = await UpdateChecker.GetLatestVersionAsync();
        if (latest is not null && Version.TryParse(latest, out var latestVersion) && latestVersion > _currentVersion)
            _updateVersion = latest;
    }

    private async Task TriggerSync()
    {
        _syncing = true;
        _syncMessage = null;
        try
        {
            await SyncService.RunSyncAsync();
            _syncMessage = "Sync completed at " + DateTime.Now.ToString("T");
            _lastSync = DateTime.UtcNow;
        }
        finally
        {
            _syncing = false;
        }
    }
}
