@page "/endpoints"
@using DriftDNS.Core.Models
@using DriftDNS.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@using DriftDNS.Core.Interfaces
@inject DriftDnsDbContext Db
@inject NavigationManager Nav
@inject IEnumerable<IDnsProvider> DnsProviders
@inject IDnsSyncService SyncService

<PageTitle>DNS Endpoints – DriftDNS</PageTitle>

<h1>DNS Endpoints</h1>

@if (!_showForm)
{
    <button class="btn btn-primary mb-3" @onclick="ShowAddForm"><i class="bi bi-plus-lg me-1"></i>Add Endpoint</button>
}

@if (_showNoProviderModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">No providers configured</h5>
                    <button type="button" class="btn-close" @onclick="() => _showNoProviderModal = false"></button>
                </div>
                <div class="modal-body">
                    <p>You need at least one active provider account before adding a DNS endpoint.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _showNoProviderModal = false"><i class="bi bi-x-lg me-1"></i>Cancel</button>
                    <button class="btn btn-primary" @onclick="GoToProviders"><i class="bi bi-gear me-1"></i>Configure a Provider</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_deleteTarget is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete Endpoint</h5>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete <strong>@_deleteTarget.Hostname</strong>?</p>
                    <p class="text-danger mb-0">This action is irreversible.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelDelete" disabled="@_deleting"><i class="bi bi-x-lg me-1"></i>Cancel</button>
                    <button class="btn btn-danger" @onclick="ConfirmDelete" disabled="@_deleting">
                        @if (_deleting) {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        } else {
                            <i class="bi bi-trash me-1"></i>
                        }
                        @(_deleting ? "Deleting..." : "Delete")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showForm)
{
    <div class="card mb-3">
        <div class="card-body">
            <h5>@(_editing ? "Edit" : "New") Endpoint</h5>
            <div class="mb-2">
                <label>Provider Account</label>
                <select class="form-select" value="@_form.ProviderAccountId" @onchange="OnProviderChanged">
                    @foreach (var p in _providers)
                    {
                        <option value="@p.Id">@p.Name</option>
                    }
                </select>
            </div>
            <div class="mb-2">
                <label>Zone</label>
                @if (_zonesLoading)
                {
                    <div class="form-control text-muted">Loading zones…</div>
                }
                else if (_zonesError is not null)
                {
                    <input class="form-control" @bind="_form.ZoneName" placeholder="Enter zone manually" />
                    <div class="form-text text-danger">@_zonesError</div>
                }
                else
                {
                    <select class="form-select" value="@_form.ZoneName" @onchange="OnZoneChanged">
                        <option value="">— select a zone —</option>
                        @foreach (var z in _zones)
                        {
                            <option value="@z">@z</option>
                        }
                    </select>
                }
            </div>
            <div class="mb-2">
                <label>Record Type</label>
                <select class="form-select" value="@_form.RecordType" @onchange="OnRecordTypeChanged">
                    <option>A</option>
                    <option>AAAA</option>
                </select>
            </div>
            <div class="mb-2">
                <label>Hostname</label>
                @if (_hostnamesLoading)
                {
                    <div class="form-control text-muted">Loading hostnames…</div>
                }
                else if (_hostnamesError is not null)
                {
                    <input class="form-control" @bind="_form.Hostname" placeholder="Enter hostname manually" />
                    <div class="form-text text-danger">@_hostnamesError</div>
                }
                else if (_hostnames.Count > 0)
                {
                    <select class="form-select" value="@_form.Hostname" @onchange="OnHostnameChanged">
                        <option value="">— select a hostname —</option>
                        @foreach (var h in _hostnames)
                        {
                            <option value="@h.Name" disabled="@h.AlreadyTracked">
                                @h.Name@(h.AlreadyTracked ? " (already tracked)" : "")
                            </option>
                        }
                    </select>
                }
                else
                {
                    <input class="form-control" @bind="_form.Hostname" placeholder="@(string.IsNullOrEmpty(_form.ZoneName) ? "Select a zone first" : "No records found, enter manually")" />
                }
            </div>
            @if (_ttlWarning)
            {
                <div class="alert alert-warning py-2 mb-2">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i>
                    This record has a high TTL (<strong>@_detectedTtl s</strong>). For dynamic DNS, set it to <strong>60–300 seconds</strong> in your provider to ensure fast propagation when your IP changes.
                </div>
            }
<button class="btn btn-success" @onclick="SaveEndpoint" disabled="@(_zonesLoading || _hostnamesLoading || _saving)">
                @if (_saving) {
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                } else {
                    <i class="bi bi-check-lg me-1"></i>
                }
                @(_saving ? "Saving..." : "Save")
            </button>
            <button class="btn btn-secondary ms-2" @onclick="CancelForm" disabled="@_saving"><i class="bi bi-x-lg me-1"></i>Cancel</button>
            @if (_error is not null) { <span class="text-danger ms-2">@_error</span> }
        </div>
    </div>
}

@if (_endpoints.Count == 0)
{
    <p class="text-muted">No endpoints configured.</p>
}
else
{
    @foreach (var group in _endpoints.GroupBy(e => e.ZoneName).OrderBy(g => g.Key))
    {
        <div class="zone-header mt-4 mb-0">
            <span class="zone-label">Domain</span>
            <span class="zone-name">@group.Key</span>
            <span class="zone-count">@group.Count() record@(group.Count() == 1 ? "" : "s")</span>
        </div>
        <table class="table table-striped endpoint-table mb-4">
            <colgroup>
                <col class="col-hostname" />
                <col class="col-type" />
                <col class="col-provider" />
                <col class="col-ttl" />
                <col class="col-status" />
                <col class="col-actions" />
            </colgroup>
            <thead>
                <tr>
                    <th>Hostname</th>
                    <th>Type</th>
                    <th>Provider</th>
                    <th>TTL</th>
                    <th>Last Sync</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ep in group.OrderBy(e => e.Hostname))
                {
                    <tr class="@(!ep.Enabled ? "table-secondary text-muted" : "")">
                        <td>@ep.Hostname</td>
                        <td>@ep.RecordType</td>
                        <td>@ep.ProviderAccount?.Name</td>
                        <td>
                            @ep.TTL
                            @if (ep.TTL > 300)
                            {
                                <i class="bi bi-exclamation-triangle-fill text-warning ms-1"
                                   data-bs-toggle="tooltip"
                                   title="TTL is high (@(ep.TTL)s). For dynamic DNS, set it to 60–300s in your provider."
                                   style="cursor:default"></i>
                            }
                        </td>
                        <td>@SyncStatusBadge(ep)</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditEndpoint(ep)"><i class="bi bi-pencil me-1"></i>Edit</button>
                            <button class="btn btn-sm @(ep.Enabled ? "btn-outline-warning" : "btn-outline-success") ms-1" @onclick="() => ToggleEndpoint(ep)" disabled="@_toggling.Contains(ep.Id)" title="@(ep.Enabled ? "Disable" : "Enable")">
                                @if (_toggling.Contains(ep.Id)) {
                                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                } else {
                                    <i class="bi @(ep.Enabled ? "bi-pause-circle" : "bi-play-circle")"></i>
                                }
                            </button>
                            <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => AskDelete(ep)"><i class="bi bi-trash me-1"></i>Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private List<DnsEndpoint> _endpoints = [];
    private List<ProviderAccount> _providers = [];
    private bool _showForm;
    private bool _editing;
    private bool _showNoProviderModal;
    private DnsEndpoint _form = new();
    private string? _error;
    private DnsEndpoint? _deleteTarget;
    private List<string> _zones = [];
    private bool _zonesLoading;
    private string? _zonesError;
    private List<(string Name, bool AlreadyTracked)> _hostnames = [];
    private bool _hostnamesLoading;
    private string? _hostnamesError;
    private bool _saving;
    private bool _deleting;
    private HashSet<Guid> _toggling = [];
    private bool _ttlWarning;
    private int _detectedTtl;

    private const int TtlWarningThreshold = 300;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _endpoints = await Db.DnsEndpoints.Include(e => e.ProviderAccount).Include(e => e.SyncState).ToListAsync();
        _providers = await Db.ProviderAccounts.Where(p => p.IsEnabled).ToListAsync();
    }

    private async Task ShowAddForm()
    {
        if (_providers.Count == 0)
        {
            _showNoProviderModal = true;
            return;
        }

        _form = new DnsEndpoint { RecordType = "A", ProviderAccountId = _providers[0].Id };
        _editing = false;
        _showForm = true;
        _error = null;
        _hostnames = [];
        _hostnamesError = null;
        _ttlWarning = false;
        await FetchZonesAsync(_providers[0].Id);
    }

    private void GoToProviders() => Nav.NavigateTo("/providers");

    private async Task EditEndpoint(DnsEndpoint ep)
    {
        _form = new DnsEndpoint
        {
            Id = ep.Id,
            Hostname = ep.Hostname,
            ZoneName = ep.ZoneName,
            RecordType = ep.RecordType,
            ProviderAccountId = ep.ProviderAccountId,
            TTL = ep.TTL,
            Enabled = ep.Enabled,
            CreatedAt = ep.CreatedAt,
        };
        _editing = true;
        _showForm = true;
        _error = null;
        _hostnames = [];
        _hostnamesError = null;
        _ttlWarning = ep.TTL > TtlWarningThreshold;
        _detectedTtl = ep.TTL;
        await FetchZonesAsync(ep.ProviderAccountId);
        if (!string.IsNullOrEmpty(ep.ZoneName))
            await FetchHostnamesAsync(ep.ProviderAccountId, ep.ZoneName, ep.RecordType);
    }

    private async Task OnProviderChanged(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            _form.ProviderAccountId = id;
            _form.ZoneName = string.Empty;
            _form.Hostname = string.Empty;
            _hostnames = [];
            _hostnamesError = null;
            _ttlWarning = false;
            await FetchZonesAsync(id);
        }
    }

    private async Task OnZoneChanged(ChangeEventArgs e)
    {
        _form.ZoneName = e.Value?.ToString() ?? string.Empty;
        _form.Hostname = string.Empty;
        _ttlWarning = false;
        if (!string.IsNullOrEmpty(_form.ZoneName))
            await FetchHostnamesAsync(_form.ProviderAccountId, _form.ZoneName, _form.RecordType);
        else
        {
            _hostnames = [];
            _hostnamesError = null;
        }
    }

    private async Task OnRecordTypeChanged(ChangeEventArgs e)
    {
        _form.RecordType = e.Value?.ToString() ?? "A";
        _form.Hostname = string.Empty;
        _ttlWarning = false;
        if (!string.IsNullOrEmpty(_form.ZoneName))
            await FetchHostnamesAsync(_form.ProviderAccountId, _form.ZoneName, _form.RecordType);
        else
        {
            _hostnames = [];
            _hostnamesError = null;
        }
    }

    private async Task OnHostnameChanged(ChangeEventArgs e)
    {
        _form.Hostname = e.Value?.ToString() ?? string.Empty;
        _ttlWarning = false;
        if (string.IsNullOrEmpty(_form.Hostname)) return;

        var account = _providers.FirstOrDefault(p => p.Id == _form.ProviderAccountId);
        if (account is null) return;
        var provider = DnsProviders.FirstOrDefault(p =>
            p.Name.Equals(account.ProviderType, StringComparison.OrdinalIgnoreCase));
        if (provider is null) return;

        try
        {
            var ttl = await provider.VerifyRecordAsync(account, _form);
            if (ttl is not null)
            {
                _detectedTtl = ttl.Value;
                _form.TTL = ttl.Value;
                _ttlWarning = ttl.Value > TtlWarningThreshold;
            }
        }
        catch { }
    }

    private async Task FetchZonesAsync(Guid providerAccountId)
    {
        var account = _providers.FirstOrDefault(p => p.Id == providerAccountId);
        if (account is null) return;

        var provider = DnsProviders.FirstOrDefault(p =>
            p.Name.Equals(account.ProviderType, StringComparison.OrdinalIgnoreCase));
        if (provider is null) return;

        _zonesLoading = true;
        _zonesError = null;
        _zones = [];
        StateHasChanged();

        try
        {
            _zones = (await provider.ListZonesAsync(account)).ToList();
        }
        catch (Exception ex)
        {
            _zonesError = ex.Message;
        }
        finally
        {
            _zonesLoading = false;
        }
    }

    private async Task FetchHostnamesAsync(Guid providerAccountId, string zoneName, string recordType)
    {
        var account = _providers.FirstOrDefault(p => p.Id == providerAccountId);
        if (account is null) return;

        var provider = DnsProviders.FirstOrDefault(p =>
            p.Name.Equals(account.ProviderType, StringComparison.OrdinalIgnoreCase));
        if (provider is null) return;

        _hostnamesLoading = true;
        _hostnamesError = null;
        _hostnames = [];
        StateHasChanged();

        try
        {
            var names = await provider.ListHostnamesAsync(account, zoneName, recordType);
            _hostnames = names.Select(h => (
                Name: h,
                AlreadyTracked: _endpoints.Any(e =>
                    e.Hostname == h &&
                    e.ZoneName == zoneName &&
                    e.RecordType == recordType &&
                    e.ProviderAccountId == _form.ProviderAccountId &&
                    e.Id != _form.Id)
            )).ToList();
        }
        catch (Exception ex)
        {
            _hostnamesError = ex.Message;
        }
        finally
        {
            _hostnamesLoading = false;
        }
    }

    private async Task SaveEndpoint()
    {
        if (string.IsNullOrWhiteSpace(_form.Hostname) || string.IsNullOrWhiteSpace(_form.ZoneName))
        {
            _error = "Hostname and Zone are required.";
            return;
        }

        _saving = true;
        try
        {
            if (_editing)
            {
                var existing = await Db.DnsEndpoints.FindAsync(_form.Id);
                if (existing is not null)
                {
                    existing.Hostname = _form.Hostname;
                    existing.ZoneName = _form.ZoneName;
                    existing.RecordType = _form.RecordType;
                    existing.ProviderAccountId = _form.ProviderAccountId;
                    existing.TTL = _form.TTL;
                    existing.Enabled = _form.Enabled;
                }
            }
            else
            {
                _form.Id = Guid.NewGuid();
                _form.CreatedAt = DateTime.UtcNow;
                Db.DnsEndpoints.Add(_form);
                await Db.SaveChangesAsync();
                await SyncService.SyncEndpointAsync(_form.Id);
                _showForm = false;
                await LoadAsync();
                return;
            }

            await Db.SaveChangesAsync();
            _showForm = false;
            await LoadAsync();
        }
        finally
        {
            _saving = false;
        }
    }

    private void AskDelete(DnsEndpoint ep) => _deleteTarget = ep;
    private void CancelDelete() => _deleteTarget = null;

    private async Task ConfirmDelete()
    {
        if (_deleteTarget is null) return;
        _deleting = true;
        try
        {
            Db.DnsEndpoints.Remove(_deleteTarget);
            await Db.SaveChangesAsync();
            _deleteTarget = null;
            await LoadAsync();
        }
        finally
        {
            _deleting = false;
        }
    }

    private void CancelForm() => _showForm = false;

    private static MarkupString SyncStatusBadge(DnsEndpoint ep)
    {
        if (!ep.Enabled)
            return new MarkupString("<span class=\"badge bg-secondary\">Disabled</span>");

        var state = ep.SyncState;
        if (state is null)
            return new MarkupString("<span class=\"badge bg-secondary\">Never</span>");

        if (state.LastError is not null)
        {
            var escaped = System.Web.HttpUtility.HtmlAttributeEncode(state.LastError);
            return new MarkupString(
                $"<span class=\"badge bg-danger\" title=\"{escaped}\" style=\"cursor:default\"><i class=\"bi bi-exclamation-triangle me-1\"></i>Error</span>");
        }

        return new MarkupString(
            $"<span class=\"badge bg-success\"><i class=\"bi bi-check-lg me-1\"></i>OK</span>");
    }

    private async Task ToggleEndpoint(DnsEndpoint ep)
    {
        _toggling.Add(ep.Id);
        try
        {
            var entity = await Db.DnsEndpoints.FindAsync(ep.Id);
            if (entity is not null)
            {
                entity.Enabled = !entity.Enabled;
                await Db.SaveChangesAsync();
                ep.Enabled = entity.Enabled;
            }
        }
        finally
        {
            _toggling.Remove(ep.Id);
        }
    }
}
