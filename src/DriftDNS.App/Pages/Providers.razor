@page "/providers"
@using DriftDNS.Core.Models
@using DriftDNS.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@using System.Text.Json
@using DriftDNS.Core.Interfaces
@using DriftDNS.Infrastructure.Security
@inject DriftDnsDbContext Db
@inject IEnumerable<IDnsProvider> DnsProviders
@inject ICredentialProtector CredentialProtector

<PageTitle>Providers – DriftDNS</PageTitle>

<h1>Provider Accounts</h1>

@if (!_showForm)
{
    <button class="btn btn-primary mb-3" @onclick="ShowAddForm"><i class="bi bi-plus-lg me-1"></i>Add Provider</button>
}

@if (_showForm)
{
    <div class="card mb-3">
        <div class="card-body">
            <h5>@(_editing ? "Edit" : "New") Provider</h5>
            <div class="mb-2">
                <label>Name</label>
                <input class="form-control" @bind="_name" />
            </div>
            <div class="mb-3">
                <label class="form-label">Provider Type</label>
                <div class="d-flex gap-3 flex-wrap">
                    <div class="provider-card @(_providerType == "Route53" ? "selected" : "")" @onclick='() => SelectProvider("Route53")'>
                        <svg viewBox="0 0 80 52" width="64" height="42" xmlns="http://www.w3.org/2000/svg">
                            <text x="40" y="30" text-anchor="middle" fill="#FF9900" font-size="24" font-weight="900" font-family="Arial">aws</text>
                            <path d="M22 42 Q40 51 58 42" fill="none" stroke="#FF9900" stroke-width="3" stroke-linecap="round"/>
                            <path d="M53 39 L59 42 L55 47" fill="none" stroke="#FF9900" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <span>AWS Route53</span>
                    </div>
                    <div class="provider-card @(_providerType == "Cloudflare" ? "selected" : "")" @onclick='() => SelectProvider("Cloudflare")'>
                        <svg viewBox="0 0 80 52" width="64" height="42" xmlns="http://www.w3.org/2000/svg">
                            <path fill="#F6821F" d="M56.5 29.4l.6-2.2c.7-2.5.4-4.8-1-6.4-1.3-1.5-3.3-2.4-5.6-2.4h-.5c-1-3.8-4.4-6.5-8.5-6.5-3 0-5.8 1.5-7.5 3.9-.7-.2-1.5-.4-2.3-.4-3.5 0-6.4 2.6-6.4 5.9 0 .4 0 .7.1 1-2.4.7-4.1 2.9-4.1 5.4 0 3.1 2.5 5.5 5.5 5.5h29c2.6 0 4.7-1.7 5.3-4.2l-.6.4z"/>
                        </svg>
                        <span>Cloudflare</span>
                    </div>
                </div>
            </div>
            @if (_providerType == "Route53")
            {
                <div class="mb-2">
                    <label>Access Key</label>
                    <input class="form-control" @bind="_accessKey" placeholder="@(_editing ? "••••••••  (leave blank to keep current)" : "")" />
                </div>
                <div class="mb-2">
                    <label>Secret Key</label>
                    <input class="form-control" type="password" @bind="_secretKey" placeholder="@(_editing ? "••••••••  (leave blank to keep current)" : "")" />
                </div>
            }
            else if (_providerType == "Cloudflare")
            {
                <div class="mb-2">
                    <label>API Token</label>
                    <input class="form-control" type="password" @bind="_accessKey" placeholder="@(_editing ? "••••••••  (leave blank to keep current)" : "")" />
                    <div class="form-text">Create a token with <strong>Zone:Read</strong> and <strong>DNS:Edit</strong> permissions.</div>
                </div>
            }
<button class="btn btn-success" @onclick="SaveProvider" disabled="@_saving">
                @if (_saving) {
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                } else {
                    <i class="bi bi-check-lg me-1"></i>
                }
                @(_saving ? "Saving..." : "Save")
            </button>
            <button class="btn btn-secondary ms-2" @onclick="CancelForm" disabled="@_saving"><i class="bi bi-x-lg me-1"></i>Cancel</button>
            @if (_error is not null) { <span class="text-danger ms-2">@_error</span> }
        </div>
    </div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Created</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in _accounts)
        {
            <tr class="@(!p.IsEnabled ? "table-secondary text-muted" : "")">
                <td>@p.Name</td>
                <td>@p.ProviderType</td>
                <td>@p.CreatedAt.ToString("g")</td>
                <td>
                    <button class="btn btn-sm btn-outline-info" @onclick="() => TestProvider(p)" disabled="@(_testing.Contains(p.Id) || !p.IsEnabled)">
                        @if (_testing.Contains(p.Id)) {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        } else {
                            <i class="bi bi-wifi me-1"></i>
                        }
                        @(_testing.Contains(p.Id) ? "Testing…" : "Test")
                    </button>
                    <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="() => EditProvider(p)"><i class="bi bi-pencil me-1"></i>Edit</button>
                    <button class="btn btn-sm @(p.IsEnabled ? "btn-outline-warning" : "btn-outline-success") ms-1" @onclick="() => ToggleProvider(p)" disabled="@_toggling.Contains(p.Id)" title="@(p.IsEnabled ? "Disable" : "Enable")">
                        @if (_toggling.Contains(p.Id)) {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        } else {
                            <i class="bi @(p.IsEnabled ? "bi-pause-circle" : "bi-play-circle")"></i>
                        }
                    </button>
                    <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => AskDelete(p)"><i class="bi bi-trash me-1"></i>Delete</button>
                    @if (_testResults.TryGetValue(p.Id, out var result))
                    {
                        <span class="ms-2 @(result.Success ? "text-success" : "text-danger")">
                            @(result.Success ? "✓ OK" : $"✗ {result.Message}")
                        </span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (_deleteTarget is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete Provider</h5>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete <strong>@_deleteTarget.Name</strong>?</p>
                    @if (_deleteEndpointCount > 0)
                    {
                        <div class="alert alert-danger py-2 mb-2">
                            <i class="bi bi-exclamation-triangle-fill me-1"></i>
                            This will also permanently delete <strong>@_deleteEndpointCount endpoint@(_deleteEndpointCount == 1 ? "" : "s")</strong> associated with this provider.
                        </div>
                    }
                    <p class="text-danger mb-0">This action is irreversible.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelDelete" disabled="@_deleting"><i class="bi bi-x-lg me-1"></i>Cancel</button>
                    <button class="btn btn-danger" @onclick="ConfirmDelete" disabled="@_deleting">
                        @if (_deleting) {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        } else {
                            <i class="bi bi-trash me-1"></i>
                        }
                        @(_deleting ? "Deleting..." : "Delete")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ProviderAccount> _accounts = [];
    private bool _showForm;
    private bool _editing;
    private Guid _editId;
    private string _name = string.Empty;
    private string _providerType = "Route53";
    private string _accessKey = string.Empty;
    private string _secretKey = string.Empty;
    private bool _isEnabled = true;
    private string? _error;
    private ProviderAccount? _deleteTarget;
    private int _deleteEndpointCount;
    private HashSet<Guid> _testing = [];
    private Dictionary<Guid, (bool Success, string Message)> _testResults = [];
    private bool _saving;
    private bool _deleting;
    private HashSet<Guid> _toggling = [];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync() =>
        _accounts = await Db.ProviderAccounts.ToListAsync();

    private void SelectProvider(string type)
    {
        _providerType = type;
        _accessKey = string.Empty;
        _secretKey = string.Empty;
        _error = null;
    }

    private void ShowAddForm()
    {
        _name = string.Empty;
        _providerType = "Route53";
        _accessKey = string.Empty;
        _secretKey = string.Empty;
        _isEnabled = true;
        _editing = false;
        _showForm = true;
        _error = null;
    }

    private void EditProvider(ProviderAccount p)
    {
        _editId = p.Id;
        _name = p.Name;
        _providerType = p.ProviderType;
        _isEnabled = p.IsEnabled;
        _editing = true;
        _showForm = true;
        _error = null;
        // Don't pre-fill credentials for security
        _accessKey = string.Empty;
        _secretKey = string.Empty;
    }

    private async Task SaveProvider()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            _error = "Name is required.";
            return;
        }

        if (_providerType == "Cloudflare" && string.IsNullOrWhiteSpace(_accessKey) && !_editing)
        {
            _error = "API Token is required.";
            return;
        }

        if (_providerType == "Route53" && !_editing)
        {
            if (string.IsNullOrWhiteSpace(_accessKey))
            {
                _error = "Access Key is required.";
                return;
            }
            if (string.IsNullOrWhiteSpace(_secretKey))
            {
                _error = "Secret Key is required.";
                return;
            }
        }

        _saving = true;
        try
        {
                if (_editing)
            {
                var existing = await Db.ProviderAccounts.FindAsync(_editId);
                if (existing is not null)
                {
                    existing.Name = _name;
                    existing.ProviderType = _providerType;
                    existing.IsEnabled = _isEnabled;
                    if (!string.IsNullOrWhiteSpace(_accessKey))
                    {
                        var json = _providerType == "Cloudflare"
                            ? JsonSerializer.Serialize(new { ApiToken = _accessKey })
                            : JsonSerializer.Serialize(new { AccessKey = _accessKey, SecretKey = _secretKey });
                        existing.EncryptedCredentials = CredentialProtector.Protect(json);
                    }
                }
            }
            else
            {
                var json = _providerType == "Cloudflare"
                    ? JsonSerializer.Serialize(new { ApiToken = _accessKey })
                    : JsonSerializer.Serialize(new { AccessKey = _accessKey, SecretKey = _secretKey });
                Db.ProviderAccounts.Add(new ProviderAccount
                {
                    Name = _name,
                    ProviderType = _providerType,
                    EncryptedCredentials = CredentialProtector.Protect(json),
                    IsEnabled = _isEnabled,
                });
            }

            await Db.SaveChangesAsync();
            _showForm = false;
            await LoadAsync();
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task AskDelete(ProviderAccount p)
    {
        _deleteTarget = p;
        _deleteEndpointCount = await Db.DnsEndpoints.CountAsync(e => e.ProviderAccountId == p.Id);
    }
    private void CancelDelete() => _deleteTarget = null;

    private async Task ConfirmDelete()
    {
        if (_deleteTarget is null) return;
        _deleting = true;
        try
        {
            Db.ProviderAccounts.Remove(_deleteTarget);
            await Db.SaveChangesAsync();
            _deleteTarget = null;
            await LoadAsync();
        }
        finally
        {
            _deleting = false;
        }
    }

    private void CancelForm() => _showForm = false;

    private async Task ToggleProvider(ProviderAccount p)
    {
        _toggling.Add(p.Id);
        try
        {
            var entity = await Db.ProviderAccounts.FindAsync(p.Id);
            if (entity is not null)
            {
                entity.IsEnabled = !entity.IsEnabled;
                await Db.SaveChangesAsync();
                p.IsEnabled = entity.IsEnabled;
            }
        }
        finally
        {
            _toggling.Remove(p.Id);
        }
    }

    private async Task TestProvider(ProviderAccount account)
    {
        _testing.Add(account.Id);
        _testResults.Remove(account.Id);
        StateHasChanged();

        var provider = DnsProviders.FirstOrDefault(p =>
            p.Name.Equals(account.ProviderType, StringComparison.OrdinalIgnoreCase));

        if (provider is null)
        {
            _testResults[account.Id] = (false, $"No provider implementation for '{account.ProviderType}'");
        }
        else
        {
            try
            {
                await provider.ValidateCredentialsAsync(account);
                _testResults[account.Id] = (true, "Connection successful");
            }
            catch (Exception ex)
            {
                _testResults[account.Id] = (false, ex.Message);
            }
        }

        _testing.Remove(account.Id);
    }
}
