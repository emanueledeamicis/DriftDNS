@page "/logs"
@using DriftDNS.Core.Models
@using DriftDNS.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject DriftDnsDbContext Db

<PageTitle>Sync Logs – DriftDNS</PageTitle>

<h1>Sync Logs</h1>

<table class="table table-sm table-striped">
    <thead>
        <tr>
            <th>Timestamp</th>
            <th>Endpoint</th>
            <th>Action</th>
            <th>Old IP</th>
            <th>New IP</th>
            <th>Details</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var log in _logs)
        {
            <tr class="@ActionClass(log.Action)">
                <td>@log.Timestamp.ToString("g")</td>
                <td>@log.Endpoint?.Hostname</td>
                <td>@log.Action</td>
                <td>@log.OldIp</td>
                <td>@log.NewIp</td>
                <td>@log.Details</td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<SyncLog> _logs = [];

    protected override async Task OnInitializedAsync()
    {
        _logs = await Db.SyncLogs
            .Include(l => l.Endpoint)
            .OrderByDescending(l => l.Timestamp)
            .Take(200)
            .ToListAsync();
    }

    private static string ActionClass(string action) => action switch
    {
        SyncAction.Updated => "table-success",
        SyncAction.Failed => "table-danger",
        _ => string.Empty,
    };
}
