@inject IJSRuntime JS

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand d-flex flex-column align-items-start" href="">
            <div class="d-flex align-items-center gap-2">
                <img src="driftdns.png" alt="DriftDNS" height="28" style="filter: brightness(0) invert(1);" />
                DriftDNS
            </div>
            <small style="font-size: 0.65rem; opacity: 0.6; font-weight: normal; margin-top: 4px;">v@_version</small>
        </a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="oi oi-home" aria-hidden="true"></span> Overview
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="endpoints">
                <span class="oi oi-list-rich" aria-hidden="true"></span> Endpoints
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="providers">
                <span class="oi oi-cloud" aria-hidden="true"></span> Providers
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="logs">
                <span class="oi oi-spreadsheet" aria-hidden="true"></span> Logs
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="settings">
                <span class="oi oi-cog" aria-hidden="true"></span> Settings
            </NavLink>
        </div>
        <hr class="mx-3 my-1 sidebar-divider" />
        <div class="nav-item px-3">
            <button class="nav-link w-100 text-start border-0" @onclick="ToggleTheme" @onclick:stopPropagation="true">
                @if (_isDark)
                {
                    <i class="bi bi-sun-fill nav-icon"></i><span>Light mode</span>
                }
                else
                {
                    <i class="bi bi-moon-fill nav-icon"></i><span>Dark mode</span>
                }
            </button>
        </div>
        <div class="nav-item px-3 pb-3">
            <a href="https://github.com/emanueledeamicis/DriftDNS" target="_blank" class="nav-link">
                <span class="nav-icon"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/></svg></span>
                GitHub
            </a>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private string _version = typeof(NavMenu).Assembly.GetName().Version?.ToString(3) ?? "—";
    private bool _isDark = false;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JS.InvokeAsync<string>("themeManager.get");
            _isDark = theme == "dark";
            StateHasChanged();
        }
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private async Task ToggleTheme()
    {
        _isDark = !_isDark;
        await JS.InvokeVoidAsync("themeManager.set", _isDark ? "dark" : "light");
    }
}
